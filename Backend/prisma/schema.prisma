generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Admin {
  id            String    @id @default(uuid())
  email         String    @unique
  password      String
  role          String    @default("admin")
  resetOtp      String?
  otpExpiry     DateTime?
  refresh_token String?
  created_at    DateTime  @default(now())
}

model Package {
  id          Int       @id @default(autoincrement())
  title       String
  price       Float
  duration    String
  description String
  image_url   String?
  groupSize   String?
  transport   String?
  tourType    String?
  location    String?
  tagline     String?
  rating      Float?    @default(5.0)
  timeline    Json?
  inclusions  Json?
  exclusions  Json?
  categoryId  Int?
  category    TourCategory? @relation(fields: [categoryId], references: [id])
  created_at  DateTime      @default(now())
  bookings    Booking[]
}

model TourCategory {
  id             Int       @id @default(autoincrement())
  name           String
  slug           String    @unique
  type           String    // domestic or international
  description    String?
  bannerImage    String?
  highlights     Json?
  keyHighlights  Json?
  packages       Package[]
  createdAt      DateTime  @default(now())
}

model Booking {
  id         Int      @id @default(autoincrement())
  name       String
  email      String
  phone      String?
  message    String?
  date       DateTime?
  status     String   @default("pending")
  package_id Int
  package    Package  @relation(fields: [package_id], references: [id])
  created_at DateTime @default(now())
}

model Enquiry {
  id         Int      @id @default(autoincrement())
  name       String
  email      String
  phone      String?
  subject    String?
  message    String
  created_at DateTime @default(now())
}

model Review {
  id         Int      @id @default(autoincrement())
  name       String
  rating     Int
  message    String
  created_at DateTime @default(now())
}

model Gallery {
  id         Int      @id @default(autoincrement())
  image_url  String
  public_id  String?
  created_at DateTime @default(now())
}
